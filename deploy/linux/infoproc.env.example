# OpenAI-compatible API credentials
INFOPROC_API_KEY=replace-me
INFOPROC_BASE_URL=https://your-openai-compatible-endpoint/v1
INFOPROC_MODEL=astron-code-latest

# Runtime directories
INFOPROC_STATE_DIR=/var/lib/infoproc/state
INFOPROC_MODEL_CACHE_DIR=/var/lib/infoproc/models
INFOPROC_HF_HOME=/var/lib/infoproc/hf_home
INFOPROC_STORAGE_ROOT=/srv/infoproc/storage

# Runtime tuning
INFOPROC_LOG_LEVEL=INFO
INFOPROC_SCHEDULER_MODE=auto
INFOPROC_DOCUMENT_WORKERS=2
INFOPROC_TRANSCRIBE_WORKERS=1
INFOPROC_LLM_WORKERS=2
INFOPROC_TRANSCRIPTION_DEVICE=auto
INFOPROC_PDF_ENGINE=pypdf
INFOPROC_OFFICE_CONVERTER=soffice

# Only required when diarization is enabled
HF_TOKEN=
