# Required API settings
INFOPROC_API_KEY=replace-me
INFOPROC_BASE_URL=https://your-openai-compatible-endpoint/v1
INFOPROC_MODEL=astron-code-latest

# Common runtime overrides
# CPU 机器建议设为 cpu；有 NVIDIA GPU 时设为 auto。
INFOPROC_TRANSCRIPTION_DEVICE=auto

# Optional path overrides
# INFOPROC_MODEL_CACHE_DIR=~/wuxiaoran/models
# INFOPROC_STORAGE_ROOT=~/wuxiaoran/infoproc-storage

# Optional
# 当你执行 --profile quality 时，会使用 quality_model；默认就是 large-v3。
# INFOPROC_QUALITY_MODEL=large-v3
# HF_TOKEN=
# INFOPROC_SCHEDULER_MODE=serial
# INFOPROC_DOCUMENT_WORKERS=2
# INFOPROC_TRANSCRIBE_WORKERS=1
# INFOPROC_LLM_WORKERS=2
# INFOPROC_PDF_ENGINE=pypdf
# INFOPROC_OFFICE_CONVERTER=soffice
